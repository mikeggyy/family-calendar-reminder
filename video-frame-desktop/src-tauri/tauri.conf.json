{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Video Frame Desktop",
  "version": "0.1.1",
  "identifier": "com.openclaw.videoframedesktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Video Frame Desktop",
        "width": 960,
        "height": 760,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "targets": "all",
    "icon": []
  }
}
